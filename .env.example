# Node Environment
NODE_ENV=development

# Database Configuration
# For local development with SQLite (simpler setup)
DATABASE_URL=file:./dev.db

# For production with PostgreSQL/Supabase (recommended for deployment)
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection String (URI mode)
# Replace [YOUR-PASSWORD] with your actual database password
SUPABASE_DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres

# JWT Secret (REQUIRED for authentication)
# Generate a secure random string for production using one of these methods:
# Method 1: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Method 2: openssl rand -hex 32
# Method 3: Use a password generator with 64+ characters
JWT_SECRET=your-secure-jwt-secret-here
